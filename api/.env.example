# Crystal Vision Co. — API Environment Variables
# Copy this file to .env and fill in the values

# Server (local dev only — Vercel ignores PORT)
PORT=3000

# ── Turso Database ──────────────────────────────────────────
# Create a free DB at https://turso.tech
# Local dev: use file:local.db (no token needed)
TURSO_DATABASE_URL=file:local.db
TURSO_AUTH_TOKEN=

# ── Vercel Blob ─────────────────────────────────────────────
# Auto-set by Vercel when you add a Blob store to the project.
# For local dev: create a token at https://vercel.com/account/tokens
# or run `vercel link` + `vercel env pull` to get all env vars locally.
BLOB_READ_WRITE_TOKEN=

# ── Email notifications ──────────────────────────────────────
# Resend.com — free tier: 3 000 emails/month
# Get your key at https://resend.com/api-keys
RESEND_API_KEY=
OWNER_EMAIL=info@crystalvisionusa.com

# ── Admin ────────────────────────────────────────────────────
ADMIN_PASSWORD=change-me-now

# ── CORS ─────────────────────────────────────────────────────
# Set to your Vercel domain in production (e.g. https://crystalvisionusa.vercel.app)
ALLOWED_ORIGIN=*
