# Crystal Vision Co. — API Environment Variables
# Copy this file to .env and fill in the values

# Server
PORT=3000

# Email notifications (Resend.com — free tier: 3k emails/month)
# Get your API key at https://resend.com/api-keys
RESEND_API_KEY=
OWNER_EMAIL=owner@crystalvisionco.com

# CORS (set to your domain in production)
ALLOWED_ORIGIN=*

# Stripe (Phase 2 — payment integration)
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
