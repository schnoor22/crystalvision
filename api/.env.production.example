# Crystal Vision Co. — Production API Environment
# Copy this file to api/.env and fill in real values before deploying.
# NEVER commit api/.env to git.

PORT=3000
NODE_ENV=production

# The domain where this site is served (used for CORS)
ALLOWED_ORIGIN=https://rightnowsd.org

# Admin dashboard password — CHANGE THIS before showing to customer
ADMIN_PASSWORD=changeme123

# Email notifications for quote submissions (optional — leave blank to skip)
RESEND_API_KEY=
OWNER_EMAIL=
